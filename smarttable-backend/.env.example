# Flask 应用配置
FLASK_APP=run.py
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# ⚠️  安全警告：以下密钥必须替换为强随机值！
# 生成方法：python -c "import secrets; print(secrets.token_hex(32))"
# 生产环境禁止使用默认值！
SECRET_KEY=your-secret-key-here

# 数据库配置
# DATABASE_URL=postgresql://username:password@localhost:5432/smarttable
DATABASE_URL=sqlite:///smarttable.db

# Redis 配置
REDIS_URL=redis://localhost:6379/0

# JWT 配置
# ⚠️  安全警告：JWT 密钥必须替换为强随机值！
# 生成方法：python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ACCESS_TOKEN_EXPIRES=86400

# MinIO 对象存储配置
# ⚠️  安全警告：MinIO 凭据必须替换为实际值！
# 默认的 minioadmin/minioadmin 仅用于本地开发测试，禁止用于生产！
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=smarttable
MINIO_SECURE=False

# 邮件配置（可选）
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# 日志级别
LOG_LEVEL=INFO

# 实时协作配置
ENABLE_REALTIME=false

# SocketIO 配置
SOCKETIO_MESSAGE_QUEUE=redis://localhost:6379/2
SOCKETIO_PING_TIMEOUT=60
SOCKETIO_PING_INTERVAL=25

# CORS 配置（生产环境使用，逗号分隔）
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
