# ============================================
# SmartTable Docker 基础部署环境变量配置
# ============================================
# 用途：docker-compose.yml（SQLite + 内嵌 Redis）
# 使用方法：复制此文件为 .env 并根据实际情况修改
#
# 适用场景：
# - 快速体验 Docker 部署
# - 开发/测试环境
# - 小规模生产环境（SQLite）

# ============================================
# 1. 应用基础配置
# ============================================
# 应用访问端口（主机端口映射）
APP_PORT=80

# Flask 运行环境：development | production
FLASK_ENV=production

# Flask 主机地址（容器内部）
FLASK_HOST=0.0.0.0

# Flask 端口（容器内部）
FLASK_PORT=5000

# 日志级别 (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# ============================================
# 2. 安全配置（⚠️ 生产环境必须修改！）
# ============================================
# Flask 会话密钥（用于加密 session 和 cookie）
# ⚠️ 生成方法：python -c "import secrets; print(secrets.token_hex(32))"
# ⚠️ 生产环境禁止使用默认值！
SECRET_KEY=your-secret-key-change-in-production

# JWT 令牌密钥（用于生成和验证访问令牌）
# ⚠️ 生成方法：python -c "import secrets; print(secrets.token_hex(32))"
# ⚠️ 生产环境禁止使用默认值！
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production

# JWT 访问令牌过期时间（秒），默认 24 小时
JWT_ACCESS_TOKEN_EXPIRES=86400

# ============================================
# 3. 数据存储配置
# ============================================
# 数据根目录（容器内路径）
DATA_DIR=/app/data

# 数据库连接 URL（SQLite 版本，容器内路径）
DATABASE_URL=sqlite:///app/data/smarttable.db

# 文件上传目录（容器内路径）
UPLOAD_FOLDER=/app/uploads

# 最大上传文件大小（字节），50MB
MAX_CONTENT_LENGTH=52428800

# ============================================
# 4. Redis 缓存配置（内嵌 Redis，连接本地）
# ============================================
# Redis 连接 URL（内嵌 Redis，127.0.0.1:6379）
REDIS_URL=redis://localhost:6379/0

# SocketIO 消息队列 Redis 地址
SOCKETIO_MESSAGE_QUEUE=redis://localhost:6379/2

# SocketIO 心跳超时时间（秒）
SOCKETIO_PING_TIMEOUT=60

# SocketIO 心跳间隔（秒）
SOCKETIO_PING_INTERVAL=25

# ============================================
# 5. MinIO 对象存储配置（可选）
# ============================================
# MinIO 服务端点（容器内服务名:端口）
MINIO_ENDPOINT=minio:9000

# MinIO 访问密钥
MINIO_ACCESS_KEY=minioadmin

# MinIO 秘密密钥
MINIO_SECRET_KEY=minioadmin

# MinIO 存储桶名称
MINIO_BUCKET_NAME=smarttable

# 是否使用 HTTPS 连接 MinIO
MINIO_SECURE=False

# ============================================
# 6. 邮件配置（可选）
# ============================================
# SMTP 服务器地址
MAIL_SERVER=smtp.gmail.com

# SMTP 端口
MAIL_PORT=587

# 是否使用 TLS 加密
MAIL_USE_TLS=True

# SMTP 发件人账号
MAIL_USERNAME=your-email@gmail.com

# SMTP 密码或应用专用密码
MAIL_PASSWORD=your-app-password

# ============================================
# 7. 实时协作配置
# ============================================
# 是否启用实时协作功能（WebSocket）
ENABLE_REALTIME=false

# ============================================
# 8. CORS 跨域配置（生产环境必填）
# ============================================
# 允许的访问来源（逗号分隔）
# 示例：CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
# CORS_ORIGINS=
