# SmartTable Docker 完整部署环境变量配置
# 用于 docker-compose.full.yml（生产环境）
# 复制此文件为 .env 并根据实际情况修改

# ============================================
# 应用配置
# ============================================
# 应用访问端口（主机端口映射）
APP_PORT=80

# Flask 运行环境
FLASK_ENV=production

# Flask 主机地址
FLASK_HOST=0.0.0.0

# Flask 端口（容器内部）
FLASK_PORT=5000

# 日志级别 (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# ============================================
# 安全配置（生产环境务必修改！）
# ============================================
# Flask 密钥（用于加密会话和令牌）
# 生成方法：python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-change-this-in-production

# JWT 密钥（用于生成访问令牌）
# 生成方法：python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your-jwt-secret-key-change-this-in-production

# JWT 访问令牌过期时间（秒），默认 24 小时
JWT_ACCESS_TOKEN_EXPIRES=86400

# ============================================
# PostgreSQL 数据库配置
# ============================================
# 数据库用户名
DB_USER=smarttable

# 数据库密码（生产环境务必修改）
DB_PASSWORD=smarttable123

# 数据库名称
DB_NAME=smarttable

# 数据库端口
DB_PORT=5432

# 数据库连接 URL（由 docker-compose 自动生成）
# DATABASE_URL=postgresql://smarttable:smarttable123@postgres:5432/smarttable

# ============================================
# Redis 配置
# ============================================
# Redis 密码（生产环境务必修改）
REDIS_PASSWORD=redis123

# Redis 端口
REDIS_PORT=6379

# Redis 连接 URL
REDIS_URL=redis://:redis123@redis:6379/0

# SocketIO 消息队列
SOCKETIO_MESSAGE_QUEUE=redis://:redis123@redis:6379/2

# SocketIO 心跳超时时间（秒）
SOCKETIO_PING_TIMEOUT=60

# SocketIO 心跳间隔（秒）
SOCKETIO_PING_INTERVAL=25

# ============================================
# MinIO 对象存储配置
# ============================================
# MinIO 访问密钥（生产环境务必修改）
MINIO_ACCESS_KEY=minioadmin

# MinIO 访问密钥（生产环境务必修改）
MINIO_SECRET_KEY=minioadmin123

# MinIO API 端口
MINIO_PORT=9000

# MinIO 控制台端口
MINIO_CONSOLE_PORT=9001

# MinIO 服务端点
MINIO_ENDPOINT=minio:9000

# MinIO 存储桶名称
MINIO_BUCKET_NAME=smarttable

# MinIO 是否使用 HTTPS
MINIO_SECURE=False

# ============================================
# 邮件配置（可选）
# ============================================
# SMTP 服务器地址
MAIL_SERVER=smtp.gmail.com

# SMTP 端口
MAIL_PORT=587

# 是否使用 TLS
MAIL_USE_TLS=True

# SMTP 用户名
MAIL_USERNAME=your-email@gmail.com

# SMTP 密码或应用专用密码
MAIL_PASSWORD=your-app-password

# ============================================
# 上传配置
# ============================================
# 最大上传文件大小（字节），默认 50MB
MAX_CONTENT_LENGTH=52428800

# 上传文件夹路径（容器内路径）
UPLOAD_FOLDER=/app/uploads

# ============================================
# CORS 配置（生产环境务必修改）
# ============================================
# 允许的来源（逗号分隔）
# CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ============================================
# 实时协作配置
# ============================================
# 是否启用实时协作功能
ENABLE_REALTIME=false
