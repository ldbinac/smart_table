# ============================================
# SmartTable Docker 完整部署环境变量配置
# ============================================
# 用途：docker-compose.full.yml（PostgreSQL + Redis + MinIO）
# 使用方法：复制此文件为 .env 并根据实际情况修改
#
# 适用场景：
# - 生产环境部署
# - 大规模数据存储需求
# - 需要独立对象存储服务

# ============================================
# 1. 应用基础配置
# ============================================
# 应用访问端口（主机端口映射）
APP_PORT=80

# Flask 运行环境：production（生产环境必须使用此值）
FLASK_ENV=production

# Flask 主机地址（容器内部）
FLASK_HOST=0.0.0.0

# Flask 端口（容器内部）
FLASK_PORT=5000

# 日志级别 (INFO, WARNING, ERROR, CRITICAL)
# ⚠️ 生产环境不建议使用 DEBUG
LOG_LEVEL=INFO

# ============================================
# 2. 安全配置（⚠️⚠️⚠️ 生产环境务必修改！！！）
# ============================================
# Flask 会话密钥（用于加密 session 和 cookie）
# ⚠️ 生成方法：python -c "import secrets; print(secrets.token_hex(32))"
# ⚠️⚠️⚠️ 必须替换为强随机值！否则存在安全风险！
SECRET_KEY=your-super-secret-key-change-this-in-production-immediately

# JWT 令牌密钥（用于生成和验证访问令牌）
# ⚠️ 生成方法：python -c "import secrets; print(secrets.token_hex(32))"
# ⚠️⚠️⚠️ 必须替换为强随机值！否则存在安全风险！
JWT_SECRET_KEY=your-jwt-secret-key-change-this-in-production-immediately

# JWT 访问令牌过期时间（秒），默认 24 小时
JWT_ACCESS_TOKEN_EXPIRES=86400

# ============================================
# 3. PostgreSQL 数据库配置
# ============================================
# 数据库用户名
DB_USER=smarttable

# 数据库密码（⚠️ 务必修改为强密码！）
DB_PASSWORD=change-this-password-in-production

# 数据库名称
DB_NAME=smarttable

# 数据库端口
DB_PORT=5432

# 数据库连接 URL（由 docker-compose 自动生成，通常无需手动设置）
# DATABASE_URL=postgresql://smarttable:password@postgres:5432/smarttable

# ============================================
# 4. 数据存储配置
# ============================================
# 数据根目录（容器内路径）
DATA_DIR=/app/data

# 文件上传目录（容器内路径）
UPLOAD_FOLDER=/app/uploads

# 最大上传文件大小（字节），50MB
MAX_CONTENT_LENGTH=52428800

# ============================================
# 5. Redis 缓存配置
# ============================================
# Redis 密码（⚠️ 生产环境建议设置）
REDIS_PASSWORD=change-this-redis-password

# Redis 端口
REDIS_PORT=6379

# Redis 连接 URL（容器内服务名:端口，含密码）
REDIS_URL=redis::REDIS_PASSWORD@redis:6379/0

# SocketIO 消息队列 Redis 地址
SOCKETIO_MESSAGE_QUEUE=redis::REDIS_PASSWORD@redis:6379/2

# SocketIO 心跳超时时间（秒）
SOCKETIO_PING_TIMEOUT=60

# SocketIO 心跳间隔（秒）
SOCKETIO_PING_INTERVAL=25

# ============================================
# 6. MinIO 对象存储配置
# ============================================
# MinIO API 端口（容器内部）
MINIO_PORT=9000

# MinIO 控制台端口（容器内部）
MINIO_CONSOLE_PORT=9001

# MinIO 服务端点（容器内服务名:端口）
MINIO_ENDPOINT=minio:9000

# MinIO 访问密钥（⚠️ 生产环境务必修改！）
MINIO_ACCESS_KEY=minioadmin

# MinIO 秘密密钥（⚠️ 生产环境务必修改！）
MINIO_SECRET_KEY=change-this-minio-secret

# MinIO 存储桶名称
MINIO_BUCKET_NAME=smarttable

# 是否使用 HTTPS 连接 MinIO
MINIO_SECURE=False

# ============================================
# 7. 邮件配置（可选）
# ============================================
# SMTP 服务器地址
MAIL_SERVER=smtp.gmail.com

# SMTP 端口
MAIL_PORT=587

# 是否使用 TLS 加密
MAIL_USE_TLS=True

# SMTP 发件人账号
MAIL_USERNAME=your-email@gmail.com

# SMTP 密码或应用专用密码
MAIL_PASSWORD=your-app-password

# ============================================
# 8. 实时协作配置
# ============================================
# 是否启用实时协作功能（WebSocket）
ENABLE_REALTIME=false

# ============================================
# 9. CORS 跨域配置（生产环境必填）
# ============================================
# 允许的访问来源（逗号分隔）
# ⚠️ 生产环境必须明确指定允许的域名！
# 示例：CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
CORS_ORIGINS=https://yourdomain.com
